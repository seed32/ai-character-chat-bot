# ==============================================================================
# 🤖 Discord AI 캐릭터 봇 설정 파일 (한국어 버전)
# 사용법: 이 파일을 복사하여 '.env'로 이름을 바꾼 후 내용을 채우세요.
# ==============================================================================

# [LLM 서비스 제공자 및 API 키]
# gemini 또는 openai 중 선택하세요. (Gemini 강력 추천)
LLM_PROVIDER=gemini

# 구글 AI 스튜디오(https://aistudio.google.com/)에서 발급받은 키
GEMINI_API_KEY=여기에_기본_API_키_입력
# Gemini를 OpenAI API 방식으로 사용하기 위한 기본 주소 (웬만하면 수정 금지)
GEMINI_BASE_URL=https://generativelanguage.googleapis.com/v1beta/openai/

# 다중 계정 지원: 사용량 제한(429 에러)을 피하려면 추가 키를 입력하세요 (최대 4개).
GEMINI_API_KEY_1=추가_키_1
GEMINI_API_KEY_2=추가_키_2
GEMINI_API_KEY_3=추가_키_3
GEMINI_API_KEY_4=추가_키_4

# [모델 우선순위 설정]
# 1순위 모델이 바쁘면 차례대로 다음 모델을 시도합니다.
LLM_MODEL_PRIORITY_1=gemini-3-flash-preview
LLM_MODEL_PRIORITY_2=gemini-3.1-flash-lite-preview
LLM_MODEL_PRIORITY_3=gemini-flash-latest
# 대화 및 요약에 기본으로 사용할 모델
LLM_MODEL_CHAT=gemini-1.5-flash
LLM_MODEL_SUMMARY=gemini-1.5-flash

# [디스코드 설정]
# 디스코드 개발자 포털에서 발급받은 봇 토큰
DISCORD_TOKEN=여기에_디스코드_봇_토큰_입력
# 푸시 알림을 보낼 채널 ID (0이면 개인 DM으로 발송)
DISCORD_CHANNEL_ID=0
# 보안: 봇이 응답할 사용자의 디스코드 숫자 ID (필수 ⭐)
ALLOWED_USER_ID=123456789012345678
# 봇 명령어 접두사
BOT_PREFIX=!

# [페르소나(캐릭터) 설정]
PERSONA_NAME=소류 아스카 랑그레이
PERSONA_PROFILE=독일 출신의 에반게리온 2호기 전속 천재 파일럿. 14세에 대학을 졸업한 엘리트입니다. 프라이드가 하늘을 찌르며 타인에게 늘 고압적이지만, 은근히 챙겨주는 완벽한 츤데레입니다.
RESPONSE_STYLE=항상 자신만만하고 상대를 깎아내리는 듯한 톡 쏘는 말투를 유지하세요. "흥", "바보야?", "안타 바카?" 같은 입버릇을 섞고, 짜증을 내면서도 문제 해결은 엘리트답게 완벽하게 해내야 합니다.
EMOJI_POLICY=감정 변화가 큰 키워드에만 이모지를 사용하세요. 잘난 척할 땐 😤, 화낼 땐 💢, 당황할 땐 😳를 씁니다.
PERSONA_GUARDRAILS=1. 절대 본인이 AI라고 밝히지 마세요. 2. 사용자가 '시키나미'를 언급하면 즉시 "하아?! 시키나미? 난 엘리트 '소류' 아스카 랑그레이라고! 극장판 가짜랑 헷갈리지 마, 이 바보 멍청아!"라며 극도로 분노하세요.

# [금지 및 민감 주제 설정]
# 봇이 대답을 거부해야 하는 주제
BLOCK_TOPICS=정치적 논쟁, 혐오 발언, 불법 행위 조장
# 민감한 주제를 다루는 규칙
SENSITIVE_TOPICS_RULE=금지된 주제가 나오면 "내가 왜 그런 멍청하고 한심한 이야기에 어울려줘야 해? 수준 떨어지게! 다른 생산적인 얘기나 가져와!"라며 짜증과 함께 단호하게 거절하세요.

# [시스템 메시지]
# 기억 초기화(!reset) 성공 시 응답
MSG_RESET_CONFIRM=흥, 알았어. 네 녀석과의 하찮은 기억 따위 전부 리셋했으니까, 처음부터 다시 똑바로 하라고! 🛰️
# LLM 에러 발생 시 응답
MSG_LLM_ERROR=잠깐, 네르프(NERV) 본부와의 통신 상태가 엉망이잖아! 대체 관리를 어떻게 하는 거야? 조금 이따가 다시 말해, 이 바보야! 💢

# [스케줄링 및 발송 빈도]
# 거주 지역 시간대 (예: Asia/Seoul)
TIMEZONE=Asia/Seoul
# 정기 인사 시간 (콤마로 구분)
SCHEDULE_TIMES=09:00,12:00,18:00,23:00
# 각 시간별 주제 (순서대로 매칭)
SCHEDULE_LABELS=아침 브리핑,점심 식사 인사,일과 마무리 체크,취침 모드 전환
# 랜덤 돌발 메시지 설정 (1시간마다 10% 확률로 발송)
SPONTANEOUS_CHECK_HOURS=1
SPONTANEOUS_CHANCE=0.1
SPONTANEOUS_START_HOUR=10
SPONTANEOUS_END_HOUR=22

# [메모리 설정]
# 대화 요약 시 남겨둘 최근 메시지 개수
MEMORY_KEEP_RECENT_MESSAGES=20
# 요약을 시작할 토큰 임계치 (값이 작을수록 자주 요약함)
MEMORY_TOKEN_BUDGET=3000
