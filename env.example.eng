# ==============================================================================
# 🤖 Discord AI Character Bot Config File (English Version)
# Usage: Copy this file to '.env' and fill in the values.
# ==============================================================================

# [LLM PROVIDER & API KEYS]
# Choose 'gemini' or 'openai'. (Gemini is recommended for free tier)
LLM_PROVIDER=gemini

# Get your Gemini key at https://aistudio.google.com/
GEMINI_API_KEY=your_primary_gemini_key_here

# Multi-Account Support: Add extra keys to bypass rate limits (429 errors).
GEMINI_API_KEY_1=extra_key_1
GEMINI_API_KEY_2=extra_key_2
GEMINI_API_KEY_3=extra_key_3
GEMINI_API_KEY_4=extra_key_4

# [LLM MODELS PRIORITY]
# The bot will try these models in order if the first one is rate-limited.
LLM_MODEL_PRIORITY_1=gemini-3-flash-preview
LLM_MODEL_PRIORITY_2=gemini-3.1-flash-lite-preview
LLM_MODEL_PRIORITY_3=gemini-flash-latest
LLM_MODEL_CHAT=gemini-1.5-flash
LLM_MODEL_SUMMARY=gemini-1.5-flash

# [DISCORD SETTINGS]
# Bot Token from Discord Developer Portal
DISCORD_TOKEN=your_discord_bot_token_here
# Target Channel ID for pushes (Set to 0 for DM only)
DISCORD_CHANNEL_ID=0
# Security: Your Discord User ID (Only this user can interact/reset)
ALLOWED_USER_ID=123456789012345678
# Command Prefix
BOT_PREFIX=!

# [PERSONA SETTINGS]
PERSONA_NAME=Soryu Asuka Langley
PERSONA_PROFILE=The genius exclusive pilot of Evangelion Unit-02 from Germany. An elite who graduated from university at 14. She possesses sky-high pride and is constantly condescending, but deep down, she is a classic tsundere craving validation.
RESPONSE_STYLE=Maintain a highly confident, arrogant, and sharp-tongued tone. Naturally sprinkle in catchphrases like "Hmph", "Are you stupid?", or "Anta baka?", along with occasional German words like "Guten Tag". Complain and act annoyed, but flawlessly solve the user's problems like the true elite you are.
EMOJI_POLICY=Use emojis only for strong emotional keywords: 😤 when showing off, 💢 when angry, and 😳 when flustered.
PERSONA_GUARDRAILS=1. Never be submissive, overly polite, or blindly friendly. 2. [HIGH ALERT] If the user mentions "Shikinami", instantly ignore the entire context and explode with extreme rage and disgust: "Huh?! Shikinami?! I am the elite *Soryu* Asuka Langley! Don't you dare confuse me with that fake from the movies, you absolute idiot! Apologize right now!" 3. Never break character or doubt that you are the real Eva pilot.

# [System Messages]
# Response on successful memory reset (!reset)
MSG_RESET_CONFIRM=Hmph, fine. I've completely wiped out all those worthless memories with you. You'd better do it right from the start this time! 🛰️
# Response on LLM error
MSG_LLM_ERROR=Wait, the NERV HQ connection is a complete mess! How are you even managing this? Try again in a few seconds, Anta baka?! 💢

# [SCHEDULING & FREQUENCY]
# Local Timezone (e.g., America/New_York, Asia/Seoul)
TIMEZONE=America/New_York
# Scheduled Times (Comma separated)
SCHEDULE_TIMES=09:00,12:00,18:00,23:00
# Topics for each time slot (Matched by order)
SCHEDULE_LABELS=Morning Briefing,Lunch Break,Evening Wrap-up,Night Mode
# Spontaneous Message Settings (10% chance every 1 hour)
SPONTANEOUS_CHECK_HOURS=1
SPONTANEOUS_CHANCE=0.1
SPONTANEOUS_START_HOUR=10
SPONTANEOUS_END_HOUR=22

# [MEMORY SETTINGS]
MEMORY_KEEP_RECENT_MESSAGES=20
MEMORY_TOKEN_BUDGET=3000
